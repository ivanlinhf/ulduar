APP_ENV=development

BACKEND_PORT=8080
FRONTEND_PORT=3000
BACKEND_READ_HEADER_TIMEOUT=5s
BACKEND_READ_TIMEOUT=90s
BACKEND_IDLE_TIMEOUT=120s
BACKEND_SHUTDOWN_TIMEOUT=10s
BACKEND_REQUEST_TIMEOUT=15s
BACKEND_MESSAGE_REQUEST_TIMEOUT=90s

DATABASE_URL=postgres://postgres:postgres@postgres:5432/ulduar?sslmode=disable

AZURE_STORAGE_ACCOUNT_NAME=devstoreaccount1
AZURE_STORAGE_ACCOUNT_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==
AZURE_STORAGE_BLOB_ENDPOINT=http://azurite:10000/devstoreaccount1
AZURE_STORAGE_CONTAINER=chat-attachments

AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_API_VERSION=replace-me
AZURE_OPENAI_DEPLOYMENT=gpt-5-chat
# Leave unset to use the default markdown-friendly prompt.
# Set to an empty value to disable the default prompt intentionally.
# AZURE_OPENAI_SYSTEM_PROMPT=
# Disabled by default. Set to true only for local/dev/test rollout of Azure-native web_search.
AZURE_OPENAI_ENABLE_WEB_SEARCH=false
AZURE_OPENAI_REQUEST_TIMEOUT=90s
AZURE_OPENAI_STREAM_TIMEOUT=10m
CHAT_RUN_FINALIZATION_TIMEOUT=15s
IMAGE_GENERATION_MAX_REFERENCE_IMAGE_BYTES=20971520
# Optional Azure AI Foundry FLUX config for image generation.
# When AZURE_FOUNDRY_ENDPOINT is set, image generation endpoints become active.
# Requires AZURE_FOUNDRY_API_KEY when AZURE_FOUNDRY_ENDPOINT is set.
# AZURE_FOUNDRY_ENDPOINT=https://your-foundry-resource.services.ai.azure.com
# AZURE_FOUNDRY_API_KEY=replace-me
# AZURE_FOUNDRY_FLUX_API_VERSION=preview
# AZURE_FOUNDRY_FLUX_MODEL=FLUX.2-pro
# AZURE_FOUNDRY_FLUX_MODEL_PATH=flux-2-pro
# AZURE_FOUNDRY_FLUX_REQUEST_TIMEOUT=60s

VITE_API_BASE_URL=http://localhost:8080
# Optional frontend build version. Manual local dev defaults to a fresh dev-server version if unset.
# VITE_APP_VERSION=local-dev
# Frontend-owned rollout flag for future image-generation UI. Defaults to false when unset.
VITE_IMAGE_GENERATION_ENABLED=false
